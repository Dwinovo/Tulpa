# Tool-call benchmark credentials. Copy this file to `benchmark/.env` (git-ignored)
# and fill in your key, then run:  ./gradlew :common:toolBench
# Values here are overridden by a matching shell env var or a -Dnumen.bench.* flag.

NUMEN_BENCH_API_KEY=sk-your-deepseek-key-here
NUMEN_BENCH_PROVIDER=deepseek

# DeepSeek V4 Flash. Confirm the exact id in your DeepSeek console — set it verbatim
# here. (`deepseek-chat` routes to the current-generation chat model if the flash
# variant has no separate id.)
NUMEN_BENCH_MODEL=deepseek-v4-flash

# calls per case — higher = tighter noise band, more cost. 3 is a fine default.
NUMEN_BENCH_SAMPLES=3

# Optional:
# NUMEN_BENCH_BASE_URL=https://api.deepseek.com/beta   # default matches the mod
# NUMEN_BENCH_TEMPERATURE=0                            # if your model accepts it
# NUMEN_BENCH_PROXY=127.0.0.1:7890
